{
  "name": "@appwarden/build-cloudflare-action",
  "version": "1.9.0",
  "description": "Easy-to-use GitHub Action to build Appwarden for deployment to your Cloudflare domain",
  "author": "support@appwarden.io",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/appwarden/build-cloudflare-action/issues"
  },
  "homepage": "https://github.com/appwarden/build-cloudflare-action#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/appwarden/build-cloudflare-action.git"
  },
  "keywords": [
    "appwarden",
    "github actions",
    "web3",
    "web security"
  ],
  "main": "dist/index.js",
  "files": [
    "dist",
    "action.yml"
  ],
  "scripts": {
    "build": "npm run build:action",
    "build:action": "tsup",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "check:types": "tsc --noEmit",
    "check:prettier": "prettier --check .",
    "check:ci": "npm run check:types && npm run check:prettier"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/exec": "^3.0.0",
    "parse-domain": "^8.3.1",
    "yaml": "2.9.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "js-yaml": "4.2.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.1",
    "@cloudflare/workers-types": "^5.20260719.1",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "lefthook": "^2.1.10",
    "prettier": "^3.9.5",
    "semver": "^7.8.5",
    "tsup": "8.5.1",
    "typescript": "^7.0.2",
    "vitest": "^4.0.18"
  }
}
